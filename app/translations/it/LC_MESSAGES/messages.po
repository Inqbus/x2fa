msgid "Invalid request"
msgstr "Richiesta non valida"

msgid "Unauthorized"
msgstr "Non autorizzato"

msgid "Please sign in again."
msgstr "Accedi di nuovo."

msgid "Access denied"
msgstr "Accesso negato"

msgid "You do not have permission to access this page."
msgstr "Non hai il permesso di accedere a questa pagina."

msgid "Not found"
msgstr "Non trovato"

msgid "The requested page does not exist."
msgstr "La pagina richiesta non esiste."

msgid "Too many requests"
msgstr "Troppe richieste"

msgid "Please wait a moment."
msgstr "Attendi un momento."

msgid "Internal error"
msgstr "Errore interno"

msgid "An unexpected error has occurred."
msgstr "Si è verificato un errore imprevisto."

msgid "Backup code"
msgstr "Codice di backup"

msgid "Use backup code"
msgstr "Usa codice di backup"

msgid "Each code can only be used once."
msgstr "Ogni codice può essere usato una sola volta."

msgid "After login, a new 2FA setup will be required."
msgstr "Dopo il login sarà necessaria una nuova configurazione 2FA."

msgid "8-digit backup code"
msgstr "Codice di backup a 8 cifre"

msgid "Sign in"
msgstr "Accedi"

msgid "Set up 2FA"
msgstr "Configura 2FA"

msgid "Set up security key"
msgstr "Configura chiave di sicurezza"

msgid "Use FaceID, TouchID, Windows Hello or a security key."
msgstr "Usa FaceID, TouchID, Windows Hello o una chiave di sicurezza."

msgid "Set up now"
msgstr "Configura ora"

msgid "Cancel"
msgstr "Annulla"

msgid "Choose a different method?"
msgstr "Scegliere un altro metodo?"

msgid "Back to selection"
msgstr "Torna alla selezione"

msgid "Waiting for authenticator…"
msgstr "In attesa dell’autenticatore…"

msgid "Try again"
msgstr "Riprova"

msgid "Setup failed."
msgstr "Configurazione non riuscita."

msgid "Set up device as security key"
msgstr "Configura il dispositivo come chiave di sicurezza"

msgid "Use FaceID, TouchID or Windows Hello to register this device."
msgstr "Usa FaceID, TouchID o Windows Hello per registrare questo dispositivo."

msgid "You can use:"
msgstr "Puoi usare:"

msgid "Phone"
msgstr "Telefono"

msgid "click Set up, choose Smartphone or Tablet in the browser dialog"
msgstr "clicca su Configura, scegli Smartphone o Tablet nella finestra di dialogo"

msgid "USB key"
msgstr "Chiave USB"

msgid "plug in YubiKey etc. and click"
msgstr "inserisci YubiKey ecc. e clicca"

msgid "Set up two-factor authentication"
msgstr "Configura l’autenticazione a due fattori"

msgid "Choose the method you want to use."
msgstr "Scegli il metodo che vuoi usare."

msgid "Passkey or security key"
msgstr "Passkey o chiave di sicurezza"

msgid "Phone, YubiKey, Windows Hello, FaceID, TouchID"
msgstr "Telefono, YubiKey, Windows Hello, FaceID, TouchID"

msgid "Authenticator app (TOTP)"
msgstr "App di autenticazione (TOTP)"

msgid "Google Authenticator, Authy, FreeOTP and others"
msgstr "Google Authenticator, Authy, FreeOTP e altri"

msgid "2FA set up"
msgstr "2FA configurato"

msgid "2FA successfully set up"
msgstr "2FA configurato con successo"

msgid "Save backup codes"
msgstr "Salva i codici di backup"

msgid "Important:"
msgstr "Importante:"

msgid "Write down these 10 backup codes now. They are shown only once and can be used if you lose your device. Each code is valid only once."
msgstr "Annota ora questi 10 codici di backup. Vengono mostrati una sola volta e possono essere usati se perdi il dispositivo. Ogni codice è valido una sola volta."

msgid "Have you saved all codes? Then click Continue."
msgstr "Hai salvato tutti i codici? Clicca su Continua."

msgid "Continue"
msgstr "Continua"

msgid "Set up TOTP"
msgstr "Configura TOTP"

msgid "Set up authenticator app"
msgstr "Configura l’app di autenticazione"

msgid "Scan the QR code with Google Authenticator, Aegis or another TOTP app."
msgstr "Scansiona il codice QR con Google Authenticator, Aegis o un’altra app TOTP."

msgid "Step 1:"
msgstr "Passo 1:"

msgid "Scan QR code"
msgstr "Scansiona codice QR"

msgid "Step 2:"
msgstr "Passo 2:"

msgid "Or enter secret manually"
msgstr "Oppure inserisci il segreto manualmente"

msgid "Step 3:"
msgstr "Passo 3:"

msgid "Enter the 6-digit code from the app"
msgstr "Inserisci il codice a 6 cifre dall’app"

msgid "Confirmation code"
msgstr "Codice di conferma"

msgid "Complete setup"
msgstr "Completa configurazione"

msgid "Enter 2FA code"
msgstr "Inserisci codice 2FA"

msgid "Enter authenticator code"
msgstr "Inserisci codice autenticatore"

msgid "Open your authenticator app and enter the current 6-digit code."
msgstr "Apri la tua app di autenticazione e inserisci il codice attuale a 6 cifre."

msgid "One-time code"
msgstr "Codice monouso"

msgid "Confirm"
msgstr "Conferma"

msgid "No access to the app?"
msgstr "Nessun accesso all’app?"

msgid "2FA confirm"
msgstr "Conferma 2FA"

msgid "Confirm identity"
msgstr "Conferma identità"

msgid "Problems?"
msgstr "Problemi?"

msgid "Enter TOTP code"
msgstr "Inserisci codice TOTP"

msgid "Confirmation failed."
msgstr "Conferma non riuscita."

msgid "Confirm with device"
msgstr "Conferma con dispositivo"

msgid "Confirm your identity with FaceID, TouchID or Windows Hello."
msgstr "Conferma la tua identità con FaceID, TouchID o Windows Hello."

msgid "Confirm with the device you used during setup:"
msgstr "Conferma con il dispositivo usato durante la configurazione:"

msgid "click Confirm, choose Smartphone or Tablet"
msgstr "clicca su Conferma, scegli Smartphone o Tablet"

