# Pflichtfelder — ohne diese startet X2FA nicht

# Mindestens 32 Zeichen. Generieren mit: openssl rand -hex 32
# ACHTUNG: Verlust dieses Keys macht alle TOTP-Secrets in der DB unlesbar.
X2FA_SECRET=

# Die Domain, unter der X2FA erreichbar ist (RP-ID für FIDO2)
X2FA_DOMAIN=2fa.example.com

# Optionale Felder

# Datenbankverbindung (Default: SQLite im aktuellen Verzeichnis)
# X2FA_DATABASE_URL=sqlite:///x2fa.db
# X2FA_DATABASE_URL=postgresql://user:password@localhost/x2fa
# X2FA_DATABASE_URL=mysql+pymysql://user:password@localhost/x2fa

# Bind-Adresse und Port (Default: nur localhost)
# X2FA_HOST=127.0.0.1
# X2FA_PORT=5000

# WebAuthn-Origin überschreiben (Standard: https://<X2FA_DOMAIN>)
# Für lokale Tests ohne HTTPS:
# X2FA_ORIGIN=http://localhost:5000
