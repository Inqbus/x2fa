# Spanish translations for X2FA.
msgid ""
msgstr ""
"Project-Id-Version: x2fa 2.0\n"
"Language: es\n"
"Language-Team: es\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=utf-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Invalid request"
msgstr "Solicitud no válida"

msgid "Unauthorized"
msgstr "No autorizado"

msgid "Please sign in again."
msgstr "Inicie sesión de nuevo."

msgid "Access denied"
msgstr "Acceso denegado"

msgid "You do not have permission to access this page."
msgstr "No tienes permiso para acceder a esta página."

msgid "Not found"
msgstr "No encontrado"

msgid "The requested page does not exist."
msgstr "La página solicitada no existe."

msgid "Too many requests"
msgstr "Demasiadas solicitudes"

msgid "Please wait a moment."
msgstr "Por favor, espera un momento."

msgid "Internal error"
msgstr "Error interno"

msgid "An unexpected error has occurred."
msgstr "Se ha producido un error inesperado."

msgid "Backup code"
msgstr "Código de respaldo"

msgid "Use backup code"
msgstr "Usar código de respaldo"

msgid "Each code can only be used once."
msgstr "Cada código solo puede usarse una vez."

msgid "After login, a new 2FA setup will be required."
msgstr "Después de iniciar sesión, será necesario configurar el 2FA de nuevo."

msgid "8-digit backup code"
msgstr "Código de respaldo de 8 dígitos"

msgid "Sign in"
msgstr "Iniciar sesión"

msgid "Set up 2FA"
msgstr "Configurar 2FA"

msgid "Set up security key"
msgstr "Configurar clave de seguridad"

msgid "Use FaceID, TouchID, Windows Hello or a security key."
msgstr "Usa FaceID, TouchID, Windows Hello o una clave de seguridad."

msgid "Set up now"
msgstr "Configurar ahora"

msgid "Cancel"
msgstr "Cancelar"

msgid "Choose a different method?"
msgstr "¿Elegir otro método?"

msgid "Back to selection"
msgstr "Volver a la selección"

msgid "Waiting for authenticator…"
msgstr "Esperando al autenticador…"

msgid "Try again"
msgstr "Intentar de nuevo"

msgid "Setup failed."
msgstr "Error en la configuración."

msgid "Set up device as security key"
msgstr "Configurar dispositivo como clave de seguridad"

msgid "Use FaceID, TouchID or Windows Hello to register this device."
msgstr "Usa FaceID, TouchID o Windows Hello para registrar este dispositivo."

msgid "You can use:"
msgstr "Puedes usar:"

msgid "Phone"
msgstr "Teléfono"

msgid "click Set up, choose Smartphone or Tablet in the browser dialog"
msgstr "haz clic en Configurar, elige Smartphone o Tableta en el diálogo del navegador"

msgid "USB key"
msgstr "Llave USB"

msgid "plug in YubiKey etc. and click"
msgstr "conecta el YubiKey etc. y haz clic"

msgid "Set up two-factor authentication"
msgstr "Configurar autenticación de dos factores"

msgid "Choose the method you want to use."
msgstr "Elige el método que deseas usar."

msgid "Passkey or security key"
msgstr "Clave de acceso o clave de seguridad"

msgid "Phone, YubiKey, Windows Hello, FaceID, TouchID"
msgstr "Teléfono, YubiKey, Windows Hello, FaceID, TouchID"

msgid "Authenticator app (TOTP)"
msgstr "Aplicación autenticadora (TOTP)"

msgid "Google Authenticator, Authy, FreeOTP and others"
msgstr "Google Authenticator, Authy, FreeOTP y otros"

msgid "2FA set up"
msgstr "2FA configurado"

msgid "2FA successfully set up"
msgstr "2FA configurado correctamente"

msgid "Save backup codes"
msgstr "Guardar códigos de respaldo"

msgid "Important:"
msgstr "Importante:"

msgid "Write down these 10 backup codes now. They are shown only once and can be used if you lose your device. Each code is valid only once."
msgstr "Anota estos 10 códigos de respaldo ahora. Se muestran una sola vez y pueden usarse si pierdes tu dispositivo. Cada código es válido una sola vez."

msgid "Have you saved all codes? Then click Continue."
msgstr "¿Has guardado todos los códigos? Entonces haz clic en Continuar."

msgid "Continue"
msgstr "Continuar"

msgid "Set up TOTP"
msgstr "Configurar TOTP"

msgid "Set up authenticator app"
msgstr "Configurar aplicación autenticadora"

msgid "Scan the QR code with Google Authenticator, Aegis or another TOTP app."
msgstr "Escanea el código QR con Google Authenticator, Aegis u otra aplicación TOTP."

msgid "Step 1:"
msgstr "Paso 1:"

msgid "Scan QR code"
msgstr "Escanear código QR"

msgid "Step 2:"
msgstr "Paso 2:"

msgid "Or enter secret manually"
msgstr "O introducir el secreto manualmente"

msgid "Step 3:"
msgstr "Paso 3:"

msgid "Enter the 6-digit code from the app"
msgstr "Introducir el código de 6 dígitos de la aplicación"

msgid "Confirmation code"
msgstr "Código de confirmación"

msgid "Complete setup"
msgstr "Completar configuración"

msgid "Enter 2FA code"
msgstr "Introducir código 2FA"

msgid "Enter authenticator code"
msgstr "Introducir código autenticador"

msgid "Open your authenticator app and enter the current 6-digit code."
msgstr "Abre tu aplicación autenticadora e introduce el código actual de 6 dígitos."

msgid "One-time code"
msgstr "Código de un solo uso"

msgid "Confirm"
msgstr "Confirmar"

msgid "No access to the app?"
msgstr "¿Sin acceso a la aplicación?"

msgid "2FA confirm"
msgstr "Confirmar 2FA"

msgid "Confirm identity"
msgstr "Confirmar identidad"

msgid "Problems?"
msgstr "¿Problemas?"

msgid "Enter TOTP code"
msgstr "Introducir código TOTP"

msgid "Confirmation failed."
msgstr "Confirmación fallida."

msgid "Confirm with device"
msgstr "Confirmar con dispositivo"

msgid "Confirm your identity with FaceID, TouchID or Windows Hello."
msgstr "Confirma tu identidad con FaceID, TouchID o Windows Hello."

msgid "Confirm with the device you used during setup:"
msgstr "Confirma con el dispositivo que usaste durante la configuración:"

msgid "click Confirm, choose Smartphone or Tablet"
msgstr "haz clic en Confirmar, elige Smartphone o Tableta"

