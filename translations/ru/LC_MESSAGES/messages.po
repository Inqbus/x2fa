# Russian translations for X2FA.
msgid ""
msgstr ""
"Project-Id-Version: x2fa 2.0\n"
"Language: ru\n"
"Language-Team: ru\n"
"Plural-Forms: nplurals=3; plural=(n%10==1 && n%100!=11 ? 0 : n%10>=2 && n%10<=4 && (n%100<10 || n%100>=20) ? 1 : 2);\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=utf-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Invalid request"
msgstr "Неверный запрос"

msgid "Unauthorized"
msgstr "Нет авторизации"

msgid "Please sign in again."
msgstr "Войдите снова."

msgid "Access denied"
msgstr "Доступ запрещён"

msgid "You do not have permission to access this page."
msgstr "У вас нет прав доступа к этой странице."

msgid "Not found"
msgstr "Не найдено"

msgid "The requested page does not exist."
msgstr "Запрашиваемая страница не существует."

msgid "Too many requests"
msgstr "Слишком много запросов"

msgid "Please wait a moment."
msgstr "Подождите момент."

msgid "Internal error"
msgstr "Внутренняя ошибка"

msgid "An unexpected error has occurred."
msgstr "Произошла непредвиденная ошибка."

msgid "Backup code"
msgstr "Резервный код"

msgid "Use backup code"
msgstr "Использовать резервный код"

msgid "Each code can only be used once."
msgstr "Каждый код можно использовать только один раз."

msgid "After login, a new 2FA setup will be required."
msgstr "После входа потребуется новая настройка 2FA."

msgid "8-digit backup code"
msgstr "8-значный резервный код"

msgid "Sign in"
msgstr "Войти"

msgid "Set up 2FA"
msgstr "Настроить 2FA"

msgid "Set up security key"
msgstr "Настроить ключ безопасности"

msgid "Use FaceID, TouchID, Windows Hello or a security key."
msgstr "Используйте FaceID, TouchID, Windows Hello или ключ безопасности."

msgid "Set up now"
msgstr "Настроить сейчас"

msgid "Cancel"
msgstr "Отмена"

msgid "Choose a different method?"
msgstr "Выбрать другой метод?"

msgid "Back to selection"
msgstr "Назад к выбору"

msgid "Waiting for authenticator…"
msgstr "Ожидание аутентификатора…"

msgid "Try again"
msgstr "Повторить"

msgid "Setup failed."
msgstr "Настройка не удалась."

msgid "Set up device as security key"
msgstr "Настроить устройство как ключ безопасности"

msgid "Use FaceID, TouchID or Windows Hello to register this device."
msgstr "Используйте FaceID, TouchID или Windows Hello для регистрации устройства."

msgid "You can use:"
msgstr "Вы можете использовать:"

msgid "Phone"
msgstr "Телефон"

msgid "click Set up, choose Smartphone or Tablet in the browser dialog"
msgstr "нажмите Настроить, выберите Смартфон или Планшет в диалоге браузера"

msgid "USB key"
msgstr "USB-ключ"

msgid "plug in YubiKey etc. and click"
msgstr "подключите YubiKey и нажмите"

msgid "Set up two-factor authentication"
msgstr "Настроить двухфакторную аутентификацию"

msgid "Choose the method you want to use."
msgstr "Выберите нужный метод."

msgid "Passkey or security key"
msgstr "Пасключ или ключ безопасности"

msgid "Phone, YubiKey, Windows Hello, FaceID, TouchID"
msgstr "Телефон, YubiKey, Windows Hello, FaceID, TouchID"

msgid "Authenticator app (TOTP)"
msgstr "Приложение-аутентификатор (TOTP)"

msgid "Google Authenticator, Authy, FreeOTP and others"
msgstr "Google Authenticator, Authy, FreeOTP и др."

msgid "2FA set up"
msgstr "2FA настроена"

msgid "2FA successfully set up"
msgstr "2FA успешно настроена"

msgid "Save backup codes"
msgstr "Сохраните резервные коды"

msgid "Important:"
msgstr "Важно:"

msgid "Write down these 10 backup codes now. They are shown only once and can be used if you lose your device. Each code is valid only once."
msgstr "Запишите эти 10 резервных кодов сейчас. Они отображаются только один раз и могут быть использованы при потере устройства. Каждый код действителен один раз."

msgid "Have you saved all codes? Then click Continue."
msgstr "Вы сохранили все коды? Нажмите Далее."

msgid "Continue"
msgstr "Далее"

msgid "Set up TOTP"
msgstr "Настроить TOTP"

msgid "Set up authenticator app"
msgstr "Настроить приложение-аутентификатор"

msgid "Scan the QR code with Google Authenticator, Aegis or another TOTP app."
msgstr "Отсканируйте QR-код с помощью Google Authenticator, Aegis или другого TOTP-приложения."

msgid "Step 1:"
msgstr "Шаг 1:"

msgid "Scan QR code"
msgstr "Отсканировать QR-код"

msgid "Step 2:"
msgstr "Шаг 2:"

msgid "Or enter secret manually"
msgstr "Или введите секрет вручную"

msgid "Step 3:"
msgstr "Шаг 3:"

msgid "Enter the 6-digit code from the app"
msgstr "Введите 6-значный код из приложения"

msgid "Confirmation code"
msgstr "Код подтверждения"

msgid "Complete setup"
msgstr "Завершить настройку"

msgid "Enter 2FA code"
msgstr "Введите код 2FA"

msgid "Enter authenticator code"
msgstr "Введите код аутентификации"

msgid "Open your authenticator app and enter the current 6-digit code."
msgstr "Откройте приложение-аутентификатор и введите текущий 6-значный код."

msgid "One-time code"
msgstr "Одноразовый код"

msgid "Confirm"
msgstr "Подтвердить"

msgid "No access to the app?"
msgstr "Нет доступа к приложению?"

msgid "2FA confirm"
msgstr "Подтвердить 2FA"

msgid "Confirm identity"
msgstr "Подтвердить личность"

msgid "Problems?"
msgstr "Проблемы?"

msgid "Enter TOTP code"
msgstr "Введите код TOTP"

msgid "Confirmation failed."
msgstr "Подтверждение не удалось."

msgid "Confirm with device"
msgstr "Подтвердить устройством"

msgid "Confirm your identity with FaceID, TouchID or Windows Hello."
msgstr "Подтвердите личность с помощью FaceID, TouchID или Windows Hello."

msgid "Confirm with the device you used during setup:"
msgstr "Подтвердите устройством, использованным при настройке:"

msgid "click Confirm, choose Smartphone or Tablet"
msgstr "нажмите Подтвердить, выберите Смартфон или Планшет"

