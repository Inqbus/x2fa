# Polish translations for X2FA.
msgid ""
msgstr ""
"Project-Id-Version: x2fa 2.0\n"
"Language: pl\n"
"Language-Team: pl\n"
"Plural-Forms: nplurals=3; plural=(n==1 ? 0 : n%10>=2 && n%10<=4 && (n%100<10 || n%100>=20) ? 1 : 2);\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=utf-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Invalid request"
msgstr "Nieprawidłowe żądanie"

msgid "Unauthorized"
msgstr "Brak autoryzacji"

msgid "Please sign in again."
msgstr "Zaloguj się ponownie."

msgid "Access denied"
msgstr "Odmowa dostępu"

msgid "You do not have permission to access this page."
msgstr "Nie masz uprawnień do tej strony."

msgid "Not found"
msgstr "Nie znaleziono"

msgid "The requested page does not exist."
msgstr "Strona nie istnieje."

msgid "Too many requests"
msgstr "Zbyt wiele żądań"

msgid "Please wait a moment."
msgstr "Poczekaj chwilę."

msgid "Internal error"
msgstr "Błąd wewnętrzny"

msgid "An unexpected error has occurred."
msgstr "Wystąpił nieoczekiwany błąd."

msgid "Backup code"
msgstr "Kod zapasowy"

msgid "Use backup code"
msgstr "Użyj kodu zapasowego"

msgid "Each code can only be used once."
msgstr "Każdy kod można użyć tylko raz."

msgid "After login, a new 2FA setup will be required."
msgstr "Po zalogowaniu wymagana będzie nowa konfiguracja 2FA."

msgid "8-digit backup code"
msgstr "8-cyfrowy kod zapasowy"

msgid "Sign in"
msgstr "Zaloguj się"

msgid "Set up 2FA"
msgstr "Skonfiguruj 2FA"

msgid "Set up security key"
msgstr "Skonfiguruj klucz bezpieczeństwa"

msgid "Use FaceID, TouchID, Windows Hello or a security key."
msgstr "Użyj FaceID, TouchID, Windows Hello lub klucza bezpieczeństwa."

msgid "Set up now"
msgstr "Skonfiguruj teraz"

msgid "Cancel"
msgstr "Anuluj"

msgid "Choose a different method?"
msgstr "Wybrać inną metodę?"

msgid "Back to selection"
msgstr "Powrót do wyboru"

msgid "Waiting for authenticator…"
msgstr "Oczekiwanie na autentykator…"

msgid "Try again"
msgstr "Spróbuj ponownie"

msgid "Setup failed."
msgstr "Konfiguracja nie powiodła się."

msgid "Set up device as security key"
msgstr "Skonfiguruj urządzenie jako klucz bezpieczeństwa"

msgid "Use FaceID, TouchID or Windows Hello to register this device."
msgstr "Użyj FaceID, TouchID lub Windows Hello, aby zarejestrować to urządzenie."

msgid "You can use:"
msgstr "Możesz użyć:"

msgid "Phone"
msgstr "Telefon"

msgid "click Set up, choose Smartphone or Tablet in the browser dialog"
msgstr "kliknij Skonfiguruj, wybierz Smartfon lub Tablet w oknie przeglądarki"

msgid "USB key"
msgstr "Klucz USB"

msgid "plug in YubiKey etc. and click"
msgstr "podłącz YubiKey itp. i kliknij"

msgid "Set up two-factor authentication"
msgstr "Skonfiguruj uwierzytelnianie dwuskładnikowe"

msgid "Choose the method you want to use."
msgstr "Wybierz metodę, której chcesz użyć."

msgid "Passkey or security key"
msgstr "Klucz dostępu lub klucz bezpieczeństwa"

msgid "Phone, YubiKey, Windows Hello, FaceID, TouchID"
msgstr "Telefon, YubiKey, Windows Hello, FaceID, TouchID"

msgid "Authenticator app (TOTP)"
msgstr "Aplikacja autentykator (TOTP)"

msgid "Google Authenticator, Authy, FreeOTP and others"
msgstr "Google Authenticator, Authy, FreeOTP i inne"

msgid "2FA set up"
msgstr "2FA skonfigurowane"

msgid "2FA successfully set up"
msgstr "2FA skonfigurowane pomyślnie"

msgid "Save backup codes"
msgstr "Zapisz kody zapasowe"

msgid "Important:"
msgstr "Ważne:"

msgid "Write down these 10 backup codes now. They are shown only once and can be used if you lose your device. Each code is valid only once."
msgstr "Zapisz teraz te 10 kodów zapasowych. Są wyświetlane tylko raz i można ich użyć w razie utraty urządzenia. Każdy kod jest ważny tylko raz."

msgid "Have you saved all codes? Then click Continue."
msgstr "Zapisałeś wszystkie kody? Kliknij Dalej."

msgid "Continue"
msgstr "Dalej"

msgid "Set up TOTP"
msgstr "Skonfiguruj TOTP"

msgid "Set up authenticator app"
msgstr "Skonfiguruj aplikację autentykator"

msgid "Scan the QR code with Google Authenticator, Aegis or another TOTP app."
msgstr "Zeskanuj kod QR za pomocą Google Authenticator, Aegis lub innej aplikacji TOTP."

msgid "Step 1:"
msgstr "Krok 1:"

msgid "Scan QR code"
msgstr "Zeskanuj kod QR"

msgid "Step 2:"
msgstr "Krok 2:"

msgid "Or enter secret manually"
msgstr "Lub wprowadź sekret ręcznie"

msgid "Step 3:"
msgstr "Krok 3:"

msgid "Enter the 6-digit code from the app"
msgstr "Wprowadź 6-cyfrowy kod z aplikacji"

msgid "Confirmation code"
msgstr "Kod potwierdzający"

msgid "Complete setup"
msgstr "Zakończ konfigurację"

msgid "Enter 2FA code"
msgstr "Wprowadź kod 2FA"

msgid "Enter authenticator code"
msgstr "Wprowadź kod autentykacyjny"

msgid "Open your authenticator app and enter the current 6-digit code."
msgstr "Otwórz aplikację autentykator i wprowadź aktualny 6-cyfrowy kod."

msgid "One-time code"
msgstr "Jednorazowy kod"

msgid "Confirm"
msgstr "Potwierdź"

msgid "No access to the app?"
msgstr "Brak dostępu do aplikacji?"

msgid "2FA confirm"
msgstr "Potwierdź 2FA"

msgid "Confirm identity"
msgstr "Potwierdź tożsamość"

msgid "Problems?"
msgstr "Problemy?"

msgid "Enter TOTP code"
msgstr "Wprowadź kod TOTP"

msgid "Confirmation failed."
msgstr "Potwierdzenie nie powiodło się."

msgid "Confirm with device"
msgstr "Potwierdź urządzeniem"

msgid "Confirm your identity with FaceID, TouchID or Windows Hello."
msgstr "Potwierdź swoją tożsamość za pomocą FaceID, TouchID lub Windows Hello."

msgid "Confirm with the device you used during setup:"
msgstr "Potwierdź urządzeniem użytym podczas konfiguracji:"

msgid "click Confirm, choose Smartphone or Tablet"
msgstr "kliknij Potwierdź, wybierz Smartfon lub Tablet"

