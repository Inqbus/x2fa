msgid "Invalid request"
msgstr "Ungültige Anfrage"

msgid "Unauthorized"
msgstr "Nicht autorisiert"

msgid "Please sign in again."
msgstr "Bitte melde dich erneut an."

msgid "Access denied"
msgstr "Zugriff verweigert"

msgid "You do not have permission to access this page."
msgstr "Du hast keine Berechtigung für diese Seite."

msgid "Not found"
msgstr "Nicht gefunden"

msgid "The requested page does not exist."
msgstr "Die aufgerufene Seite existiert nicht."

msgid "Too many requests"
msgstr "Zu viele Anfragen"

msgid "Please wait a moment."
msgstr "Bitte warte einen Moment."

msgid "Internal error"
msgstr "Interner Fehler"

msgid "An unexpected error has occurred."
msgstr "Ein unerwarteter Fehler ist aufgetreten."

msgid "Backup code"
msgstr "Backup-Code"

msgid "Use backup code"
msgstr "Backup-Code verwenden"

msgid "Each code can only be used once."
msgstr "Jeder Code kann nur einmal verwendet werden."

msgid "After login, a new 2FA setup will be required."
msgstr "Nach dem Login wird ein neues 2FA-Setup erforderlich sein."

msgid "8-digit backup code"
msgstr "8-stelliger Backup-Code"

msgid "Sign in"
msgstr "Anmelden"

msgid "Set up 2FA"
msgstr "2FA einrichten"

msgid "Set up security key"
msgstr "Sicherheitsschlüssel einrichten"

msgid "Use FaceID, TouchID, Windows Hello or a security key."
msgstr "Verwende FaceID, TouchID, Windows Hello oder einen Sicherheitsschlüssel."

msgid "Set up now"
msgstr "Jetzt einrichten"

msgid "Cancel"
msgstr "Abbrechen"

msgid "Choose a different method?"
msgstr "Andere Methode wählen?"

msgid "Back to selection"
msgstr "Zurück zur Auswahl"

msgid "Waiting for authenticator\u2026"
msgstr "Warte auf Authenticator\u2026"

msgid "Try again"
msgstr "Erneut versuchen"

msgid "Setup failed."
msgstr "Einrichtung fehlgeschlagen."

msgid "Set up device as security key"
msgstr "Gerät als Sicherheitsschlüssel einrichten"

msgid "Use FaceID, TouchID or Windows Hello to register this device."
msgstr "Verwende FaceID, TouchID oder Windows Hello, um dieses Gerät zu registrieren."

msgid "You can use:"
msgstr "Du kannst verwenden:"

msgid "Phone"
msgstr "Handy"

msgid "click Set up, choose Smartphone or Tablet in the browser dialog"
msgstr "klicke Einrichten, wähle im Browser-Dialog Smartphone oder Tablet"

msgid "USB key"
msgstr "USB-Schlüssel"

msgid "plug in YubiKey etc. and click"
msgstr "YubiKey o.\u00e4. einstecken und klicken"

msgid "Set up two-factor authentication"
msgstr "Zwei-Faktor-Authentifizierung einrichten"

msgid "Choose the method you want to use."
msgstr "W\u00e4hle die Methode, die du verwenden m\u00f6chtest."

msgid "Passkey or security key"
msgstr "Passkey oder Sicherheitsschl\u00fcssel"

msgid "Phone, YubiKey, Windows Hello, FaceID, TouchID"
msgstr "Handy, YubiKey, Windows Hello, FaceID, TouchID"

msgid "Authenticator app (TOTP)"
msgstr "Authenticator-App (TOTP)"

msgid "Google Authenticator, Authy, FreeOTP and others"
msgstr "Google Authenticator, Authy, FreeOTP u.a."

msgid "2FA set up"
msgstr "2FA eingerichtet"

msgid "2FA successfully set up"
msgstr "2FA erfolgreich eingerichtet"

msgid "Save backup codes"
msgstr "Backup-Codes sichern"

msgid "Important:"
msgstr "Wichtig:"

msgid "Write down these 10 backup codes now. They are shown only once and can be used if you lose your device. Each code is valid only once."
msgstr "Notiere diese 10 Backup-Codes jetzt. Sie werden nur einmal angezeigt und k\u00f6nnen bei verlorenem Ger\u00e4t verwendet werden. Jeder Code ist nur einmal g\u00fcltig."

msgid "Have you saved all codes? Then click Continue."
msgstr "Hast du alle Codes gesichert? Dann klicke auf Weiter."

msgid "Continue"
msgstr "Weiter"

msgid "Set up TOTP"
msgstr "TOTP einrichten"

msgid "Set up authenticator app"
msgstr "Authenticator-App einrichten"

msgid "Scan the QR code with Google Authenticator, Aegis or another TOTP app."
msgstr "Scanne den QR-Code mit Google Authenticator, Aegis oder einer anderen TOTP-App."

msgid "Step 1:"
msgstr "Schritt 1:"

msgid "Scan QR code"
msgstr "QR-Code scannen"

msgid "Step 2:"
msgstr "Schritt 2:"

msgid "Or enter secret manually"
msgstr "Oder Secret manuell eingeben"

msgid "Step 3:"
msgstr "Schritt 3:"

msgid "Enter the 6-digit code from the app"
msgstr "6-stelligen Code aus der App eingeben"

msgid "Confirmation code"
msgstr "Best\u00e4tigungscode"

msgid "Complete setup"
msgstr "Einrichtung abschlie\u00dfen"

msgid "Enter 2FA code"
msgstr "2FA-Code eingeben"

msgid "Enter authenticator code"
msgstr "Authenticator-Code eingeben"

msgid "Open your authenticator app and enter the current 6-digit code."
msgstr "\u00d6ffne deine Authenticator-App und gib den aktuellen 6-stelligen Code ein."

msgid "One-time code"
msgstr "Einmalcode"

msgid "Confirm"
msgstr "Best\u00e4tigen"

msgid "No access to the app?"
msgstr "Kein Zugriff auf die App?"

msgid "2FA confirm"
msgstr "2FA best\u00e4tigen"

msgid "Confirm identity"
msgstr "Identit\u00e4t best\u00e4tigen"

msgid "Problems?"
msgstr "Probleme?"

msgid "Enter TOTP code"
msgstr "TOTP-Code eingeben"

msgid "Confirmation failed."
msgstr "Best\u00e4tigung fehlgeschlagen."

msgid "Confirm with device"
msgstr "Mit Ger\u00e4t best\u00e4tigen"

msgid "Confirm your identity with FaceID, TouchID or Windows Hello."
msgstr "Best\u00e4tige deine Identit\u00e4t mit FaceID, TouchID oder Windows Hello."

msgid "Confirm with the device you used during setup:"
msgstr "Best\u00e4tige mit dem Ger\u00e4t, das du beim Einrichten verwendet hast:"

msgid "click Confirm, choose Smartphone or Tablet"
msgstr "klicke Best\u00e4tigen, w\u00e4hle Smartphone oder Tablet"
