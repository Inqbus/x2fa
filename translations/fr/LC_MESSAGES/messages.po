# French translations for X2FA.
msgid ""
msgstr ""
"Project-Id-Version: x2fa 2.0\n"
"Language: fr\n"
"Language-Team: fr\n"
"Plural-Forms: nplurals=2; plural=(n > 1);\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=utf-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Invalid request"
msgstr "Requête invalide"

msgid "Unauthorized"
msgstr "Non autorisé"

msgid "Please sign in again."
msgstr "Veuillez vous reconnecter."

msgid "Access denied"
msgstr "Accès refusé"

msgid "You do not have permission to access this page."
msgstr "Vous n’avez pas la permission d’accéder à cette page."

msgid "Not found"
msgstr "Introuvable"

msgid "The requested page does not exist."
msgstr "La page demandée n’existe pas."

msgid "Too many requests"
msgstr "Trop de requêtes"

msgid "Please wait a moment."
msgstr "Veuillez patienter un instant."

msgid "Internal error"
msgstr "Erreur interne"

msgid "An unexpected error has occurred."
msgstr "Une erreur inattendue s’est produite."

msgid "Backup code"
msgstr "Code de secours"

msgid "Use backup code"
msgstr "Utiliser un code de secours"

msgid "Each code can only be used once."
msgstr "Chaque code ne peut être utilisé qu’une seule fois."

msgid "After login, a new 2FA setup will be required."
msgstr "Après la connexion, une nouvelle configuration 2FA sera nécessaire."

msgid "8-digit backup code"
msgstr "Code de secours à 8 chiffres"

msgid "Sign in"
msgstr "Se connecter"

msgid "Set up 2FA"
msgstr "Configurer la 2FA"

msgid "Set up security key"
msgstr "Configurer la clé de sécurité"

msgid "Use FaceID, TouchID, Windows Hello or a security key."
msgstr "Utilisez FaceID, TouchID, Windows Hello ou une clé de sécurité."

msgid "Set up now"
msgstr "Configurer maintenant"

msgid "Cancel"
msgstr "Annuler"

msgid "Choose a different method?"
msgstr "Choisir une autre méthode ?"

msgid "Back to selection"
msgstr "Retour à la sélection"

msgid "Waiting for authenticator…"
msgstr "En attente de l’authentificateur…"

msgid "Try again"
msgstr "Réessayer"

msgid "Setup failed."
msgstr "La configuration a échoué."

msgid "Set up device as security key"
msgstr "Configurer l’appareil comme clé de sécurité"

msgid "Use FaceID, TouchID or Windows Hello to register this device."
msgstr "Utilisez FaceID, TouchID ou Windows Hello pour enregistrer cet appareil."

msgid "You can use:"
msgstr "Vous pouvez utiliser :"

msgid "Phone"
msgstr "Téléphone"

msgid "click Set up, choose Smartphone or Tablet in the browser dialog"
msgstr "cliquez sur Configurer, choisissez Smartphone ou Tablette dans la boîte de dialogue"

msgid "USB key"
msgstr "Clé USB"

msgid "plug in YubiKey etc. and click"
msgstr "branchez le YubiKey etc. et cliquez"

msgid "Set up two-factor authentication"
msgstr "Configurer l’authentification à deux facteurs"

msgid "Choose the method you want to use."
msgstr "Choisissez la méthode que vous souhaitez utiliser."

msgid "Passkey or security key"
msgstr "Clé d’accès ou clé de sécurité"

msgid "Phone, YubiKey, Windows Hello, FaceID, TouchID"
msgstr "Téléphone, YubiKey, Windows Hello, FaceID, TouchID"

msgid "Authenticator app (TOTP)"
msgstr "Application d’authentification (TOTP)"

msgid "Google Authenticator, Authy, FreeOTP and others"
msgstr "Google Authenticator, Authy, FreeOTP et autres"

msgid "2FA set up"
msgstr "2FA configurée"

msgid "2FA successfully set up"
msgstr "2FA configurée avec succès"

msgid "Save backup codes"
msgstr "Sauvegarder les codes de secours"

msgid "Important:"
msgstr "Important :"

msgid "Write down these 10 backup codes now. They are shown only once and can be used if you lose your device. Each code is valid only once."
msgstr "Notez ces 10 codes de secours maintenant. Ils ne sont affichés qu’une seule fois et peuvent être utilisés en cas de perte de votre appareil. Chaque code n’est valide qu’une seule fois."

msgid "Have you saved all codes? Then click Continue."
msgstr "Avez-vous sauvegardé tous les codes ? Cliquez ensuite sur Continuer."

msgid "Continue"
msgstr "Continuer"

msgid "Set up TOTP"
msgstr "Configurer TOTP"

msgid "Set up authenticator app"
msgstr "Configurer l’application d’authentification"

msgid "Scan the QR code with Google Authenticator, Aegis or another TOTP app."
msgstr "Scannez le code QR avec Google Authenticator, Aegis ou une autre application TOTP."

msgid "Step 1:"
msgstr "Étape 1 :"

msgid "Scan QR code"
msgstr "Scanner le code QR"

msgid "Step 2:"
msgstr "Étape 2 :"

msgid "Or enter secret manually"
msgstr "Ou saisir le secret manuellement"

msgid "Step 3:"
msgstr "Étape 3 :"

msgid "Enter the 6-digit code from the app"
msgstr "Saisir le code à 6 chiffres de l’application"

msgid "Confirmation code"
msgstr "Code de confirmation"

msgid "Complete setup"
msgstr "Terminer la configuration"

msgid "Enter 2FA code"
msgstr "Saisir le code 2FA"

msgid "Enter authenticator code"
msgstr "Saisir le code d’authentification"

msgid "Open your authenticator app and enter the current 6-digit code."
msgstr "Ouvrez votre application d’authentification et saisissez le code actuel à 6 chiffres."

msgid "One-time code"
msgstr "Code à usage unique"

msgid "Confirm"
msgstr "Confirmer"

msgid "No access to the app?"
msgstr "Pas d’accès à l’application ?"

msgid "2FA confirm"
msgstr "Confirmer la 2FA"

msgid "Confirm identity"
msgstr "Confirmer l’identité"

msgid "Problems?"
msgstr "Problèmes ?"

msgid "Enter TOTP code"
msgstr "Saisir le code TOTP"

msgid "Confirmation failed."
msgstr "Confirmation échouée."

msgid "Confirm with device"
msgstr "Confirmer avec l’appareil"

msgid "Confirm your identity with FaceID, TouchID or Windows Hello."
msgstr "Confirmez votre identité avec FaceID, TouchID ou Windows Hello."

msgid "Confirm with the device you used during setup:"
msgstr "Confirmez avec l’appareil utilisé lors de la configuration :"

msgid "click Confirm, choose Smartphone or Tablet"
msgstr "cliquez sur Confirmer, choisissez Smartphone ou Tablette"

