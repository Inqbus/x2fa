# Turkish translations for X2FA.
msgid ""
msgstr ""
"Project-Id-Version: x2fa 2.0\n"
"Language: tr\n"
"Language-Team: tr\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=utf-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Invalid request"
msgstr "Geçersiz istek"

msgid "Unauthorized"
msgstr "Yetkisiz"

msgid "Please sign in again."
msgstr "Lütfen tekrar giriş yapın."

msgid "Access denied"
msgstr "Erişim reddedildi"

msgid "You do not have permission to access this page."
msgstr "Bu sayfaya erişim izniniz yok."

msgid "Not found"
msgstr "Bulunamadı"

msgid "The requested page does not exist."
msgstr "İstenen sayfa mevcut değil."

msgid "Too many requests"
msgstr "Çok fazla istek"

msgid "Please wait a moment."
msgstr "Lütfen bir an bekleyin."

msgid "Internal error"
msgstr "İç hata"

msgid "An unexpected error has occurred."
msgstr "Beklenmedik bir hata oluştu."

msgid "Backup code"
msgstr "Yedek kod"

msgid "Use backup code"
msgstr "Yedek kod kullan"

msgid "Each code can only be used once."
msgstr "Her kod yalnızca bir kez kullanılabilir."

msgid "After login, a new 2FA setup will be required."
msgstr "Girişten sonra yeni bir 2FA kurulumu gerekecek."

msgid "8-digit backup code"
msgstr "8 haneli yedek kod"

msgid "Sign in"
msgstr "Giriş yap"

msgid "Set up 2FA"
msgstr "2FA kur"

msgid "Set up security key"
msgstr "Güvenlik anahtarı kur"

msgid "Use FaceID, TouchID, Windows Hello or a security key."
msgstr "FaceID, TouchID, Windows Hello veya güvenlik anahtarı kullanın."

msgid "Set up now"
msgstr "Şimdi kur"

msgid "Cancel"
msgstr "İptal"

msgid "Choose a different method?"
msgstr "Farklı bir yöntem seçin?"

msgid "Back to selection"
msgstr "Seçime dön"

msgid "Waiting for authenticator…"
msgstr "Kimlik doğrulaycı bekleniyor…"

msgid "Try again"
msgstr "Tekrar dene"

msgid "Setup failed."
msgstr "Kurulum başarısız."

msgid "Set up device as security key"
msgstr "Cihazı güvenlik anahtarı olarak kur"

msgid "Use FaceID, TouchID or Windows Hello to register this device."
msgstr "Bu cihazı kaydetmek için FaceID, TouchID veya Windows Hello kullanın."

msgid "You can use:"
msgstr "Kullanabilirsiniz:"

msgid "Phone"
msgstr "Telefon"

msgid "click Set up, choose Smartphone or Tablet in the browser dialog"
msgstr "Kur’a tıklayın, tarayıcı iletişim kutusunda Akıllı Telefon veya Tablet’i seçin"

msgid "USB key"
msgstr "USB anahtar"

msgid "plug in YubiKey etc. and click"
msgstr "YubiKey vb. takıp tıklayın"

msgid "Set up two-factor authentication"
msgstr "İki faktörlü kimlik doğrulama kur"

msgid "Choose the method you want to use."
msgstr "Kullanmak istediğiniz yöntemi seçin."

msgid "Passkey or security key"
msgstr "Geçiş anahtarı veya güvenlik anahtarı"

msgid "Phone, YubiKey, Windows Hello, FaceID, TouchID"
msgstr "Telefon, YubiKey, Windows Hello, FaceID, TouchID"

msgid "Authenticator app (TOTP)"
msgstr "Kimlik doğrulaycı uygulaması (TOTP)"

msgid "Google Authenticator, Authy, FreeOTP and others"
msgstr "Google Authenticator, Authy, FreeOTP ve diğerleri"

msgid "2FA set up"
msgstr "2FA kuruldu"

msgid "2FA successfully set up"
msgstr "2FA başarıyla kuruldu"

msgid "Save backup codes"
msgstr "Yedek kodları kaydet"

msgid "Important:"
msgstr "Önemli:"

msgid "Write down these 10 backup codes now. They are shown only once and can be used if you lose your device. Each code is valid only once."
msgstr "Bu 10 yedek kodu hemen not edin. Yalnızca bir kez görüntülenir ve cihazınızı kaybetmeniz durumunda kullanılabilir. Her kod yalnızca bir kez geçerlidir."

msgid "Have you saved all codes? Then click Continue."
msgstr "Tüm kodları kaydettiniz mi? Devam’a tıklayın."

msgid "Continue"
msgstr "Devam"

msgid "Set up TOTP"
msgstr "TOTP kur"

msgid "Set up authenticator app"
msgstr "Kimlik doğrulaycı uygulaması kur"

msgid "Scan the QR code with Google Authenticator, Aegis or another TOTP app."
msgstr "QR kodunu Google Authenticator, Aegis veya başka bir TOTP uygulamasıyla taratın."

msgid "Step 1:"
msgstr "Adım 1:"

msgid "Scan QR code"
msgstr "QR kodu tarat"

msgid "Step 2:"
msgstr "Adım 2:"

msgid "Or enter secret manually"
msgstr "Ya da gizli anahtarı elle girin"

msgid "Step 3:"
msgstr "Adım 3:"

msgid "Enter the 6-digit code from the app"
msgstr "Uygulamadaki 6 haneli kodu girin"

msgid "Confirmation code"
msgstr "Doğrulama kodu"

msgid "Complete setup"
msgstr "Kurulumu tamamla"

msgid "Enter 2FA code"
msgstr "2FA kodunu girin"

msgid "Enter authenticator code"
msgstr "Kimlik doğrulaycı kodunu girin"

msgid "Open your authenticator app and enter the current 6-digit code."
msgstr "Kimlik doğrulaycı uygulamasını açın ve geçerli 6 haneli kodu girin."

msgid "One-time code"
msgstr "Tek kullanımlık kod"

msgid "Confirm"
msgstr "Onayla"

msgid "No access to the app?"
msgstr "Uygulamaya erişemiyorsunuz?"

msgid "2FA confirm"
msgstr "2FA onayla"

msgid "Confirm identity"
msgstr "Kimliği onayla"

msgid "Problems?"
msgstr "Sorun mu var?"

msgid "Enter TOTP code"
msgstr "TOTP kodunu girin"

msgid "Confirmation failed."
msgstr "Doğrulama başarısız."

msgid "Confirm with device"
msgstr "Cihazla onayla"

msgid "Confirm your identity with FaceID, TouchID or Windows Hello."
msgstr "Kimliğinizi FaceID, TouchID veya Windows Hello ile onaylayın."

msgid "Confirm with the device you used during setup:"
msgstr "Kurulum sırasında kullandığınız cihazla onaylayın:"

msgid "click Confirm, choose Smartphone or Tablet"
msgstr "Onayla’ya tıklayın, Akıllı Telefon veya Tablet’i seçin"

